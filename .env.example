# ── Supabase ──────────────────────────────────────────────────
# Créez votre projet sur https://supabase.com
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ── France Travail API (optionnel) ────────────────────────────
# Créez votre application sur https://francetravail.io
VITE_FT_CLIENT_ID=your-client-id
VITE_FT_CLIENT_SECRET=your-client-secret

# ── Web Push VAPID (optionnel — notifications push) ───────────
# Générez vos clés : npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key
